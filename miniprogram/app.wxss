/** * 全局样式重置与变量
 * Skyline 默认采用 Flex 布局
 * 【修复说明】微信小程序不支持 @import url() 引入远程 CSS。
 * 请在后续开发中将 Phosphor 图标库的 CSS 下载到本地并重命名为 .wxss 引入。
 */

page {
  background-color: #f3f4f6;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
  height: 100vh;
  display: flex;
  flex-direction: column;
  --primary: #1d4ed8;
  --primary-light: #dbeafe;
  --text-main: #111827;
  --text-gray: #6b7280;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}